{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npx esbuild server/app.ts --bundle --format=esm --platform=node --target=node20 --packages=external --alias:@shared=./shared --tsconfig=tsconfig.json --outfile=dist/server.mjs && vite build",
  "outputDirectory": "dist/public",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "dist/server.mjs"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/uploads/(.*)", "destination": "/api/index" },
    { "source": "/((?!.*\\..*).*)", "destination": "/index.html" }
  ]
}
